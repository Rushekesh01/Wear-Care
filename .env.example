# ============================================
# SUPABASE CONFIGURATION (PostgreSQL Backend)
# ============================================
# Get these from: https://supabase.com/dashboard/project/[your-project]/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# ============================================
# GMAIL SMTP CONFIGURATION (for OTP emails)
# ============================================
# GMAIL_SMTP_USER: Your Gmail email address
# GMAIL_SMTP_PASSWORD: Your Gmail App Password (NOT your main password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_SMTP_USER=your-email@gmail.com
GMAIL_SMTP_PASSWORD=your-app-password-here

# ============================================
# FLASK CONFIGURATION
# ============================================
# Keep this secret in production
SECRET_KEY=your-secret-key-generate-random-string-here

# ============================================
# ENVIRONMENT
# ============================================
# Set to 'production' on Render, 'development' locally
FLASK_ENV=development
